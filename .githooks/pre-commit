#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

declare -a staged_cpp_files=()
declare -a staged_python_files=()

while IFS= read -r -d '' path; do
  case "$path" in
    *.c|*.cc|*.cpp|*.cxx|*.h|*.hh|*.hpp)
      if [ -f "$path" ]; then
        staged_cpp_files+=("$path")
      fi
      ;;
    *.py|*.pyi)
      if [ -f "$path" ]; then
        staged_python_files+=("$path")
      fi
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

ensure_fully_staged() {
  local tool_name="$1"
  shift
  local -a files=("$@")

  if [ "${#files[@]}" -eq 0 ]; then
    return 0
  fi

  declare -a dirty_files=()
  while IFS= read -r -d '' path; do
    dirty_files+=("$path")
  done < <(git diff --name-only --diff-filter=ACMR -z -- "${files[@]}")

  if [ "${#dirty_files[@]}" -gt 0 ]; then
    echo "pre-commit ${tool_name} refused to run on partially staged files:" >&2
    printf '  %s\n' "${dirty_files[@]}" >&2
    echo "Stage or stash the remaining changes, then commit again." >&2
    exit 1
  fi
}

if [ "${#staged_cpp_files[@]}" -gt 0 ]; then
  ensure_fully_staged "clang-format" "${staged_cpp_files[@]}"
  tools/clang_format.sh fix "${staged_cpp_files[@]}"
  git add -- "${staged_cpp_files[@]}"
fi

if [ "${#staged_python_files[@]}" -gt 0 ]; then
  ensure_fully_staged "ruff" "${staged_python_files[@]}"
  uvx ruff check --fix "${staged_python_files[@]}"
  uvx ruff format "${staged_python_files[@]}"
  git add -- "${staged_python_files[@]}"
fi
