#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

declare -a staged_files=()

while IFS= read -r -d '' path; do
  case "$path" in
    *.c|*.cc|*.cpp|*.cxx|*.h|*.hh|*.hpp)
      if [ -f "$path" ]; then
        staged_files+=("$path")
      fi
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ "${#staged_files[@]}" -eq 0 ]; then
  exit 0
fi

declare -a dirty_files=()
while IFS= read -r -d '' path; do
  dirty_files+=("$path")
done < <(git diff --name-only --diff-filter=ACMR -z -- "${staged_files[@]}")

if [ "${#dirty_files[@]}" -gt 0 ]; then
  echo "pre-commit clang-format refused to run on partially staged files:" >&2
  printf '  %s\n' "${dirty_files[@]}" >&2
  echo "Stage or stash the remaining changes, then commit again." >&2
  exit 1
fi

tools/clang_format.sh fix "${staged_files[@]}"
git add -- "${staged_files[@]}"
